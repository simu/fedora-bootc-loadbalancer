#cloud-config
# add your ssh public key here
ssh_authorized_keys: []
write_files:
  - path: /etc/ostree/auth.json
    # Edit this if you need auth for the container registry hosting your
    # bootable container. Consider using `encoding: base64`.
    content: "{}"
  - path: /etc/bootc-loadbalancer-controller-manager/config.env
    # Edit this to match your cluster's config
    content: |
      KUBECONFIG=/etc/bootc-loadbalancer-controller-manager/kubeconfig
      CLUSTER_NETWORK=192.168.100.0/24
      PRIMARY=false
  - path: /etc/bootc-loadbalancer-controller-manager/kubeconfig
    # update this with a suitable kubeconfig, consider using `encoding:
    # base64` to avoid issues with nested YAML.
    content: ""
  - path: /etc/bootc-loadbalancer-controller-manager/lbconfig.yaml
    encoding: base64
    # this is the file `examples/openshift-cloudscale.yaml` provided in
    # https://github.com/simu/bootc-load-balancer-controller. Update with a
    # `LoadBalancerConfig` and cloud provider secret that are suitable for
    # your cluster.
    content: 
runcmd: []
